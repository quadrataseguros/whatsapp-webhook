# WhatsApp Business API
VERIFY_TOKEN=quadrata123
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=

# Langflow — endereço do servidor (local ou nuvem)
# Local:  http://localhost:7860
# Tablet: http://IP-DO-PC:7860
# Nuvem:  https://seu-langflow.render.com
LANGFLOW_URL=http://localhost:7860
LANGFLOW_API_KEY=

# ── Flows por domínio (biblioteca separada para cada produto) ──────────────────
# Cada domínio usa seu próprio flow do Langflow com sua base de conhecimento.
# Cole aqui o ID do flow (UUID) de cada produto criado no Langflow.
# Se um domínio não tiver flow próprio, ele usará LANGFLOW_FLOW_ID como padrão.
LANGFLOW_FLOW_ID_SAUDE=
LANGFLOW_FLOW_ID_ODONTO=
LANGFLOW_FLOW_ID_AUTO=
LANGFLOW_FLOW_ID_VIDA=

# Flow padrão (fallback para domínios não configurados)
LANGFLOW_FLOW_ID=

# Make (fallback — só necessário se não usar Langflow)
MAKE_WEBHOOK_URL=

PORT=3000
