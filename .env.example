# WhatsApp Business API
VERIFY_TOKEN=quadrata123
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=

# Langflow — endereço do servidor (local ou nuvem)
# Local:  http://localhost:7860
# Tablet: http://IP-DO-PC:7860
# Nuvem:  https://seu-langflow.render.com
LANGFLOW_URL=http://localhost:7860
LANGFLOW_API_KEY=

# Agente Atendente (principal — obrigatório)
LANGFLOW_FLOW_ID=

# Flow de indexação RAG (obrigatório para usar PDFs de produtos)
# Configure no Langflow: File Loader → Text Splitter → Embeddings → Vector Store
# Parâmetros recomendados:
#   chunk_size:    700   (tokens por trecho — equilíbrio entre contexto e velocidade)
#   chunk_overlap: 120   (sobreposição entre trechos — preserva continuidade)
#   top_k:         4     (quantos trechos recuperar por pergunta — não exceder 5)
LANGFLOW_FLOW_ID_RAG=

# Agente Vendedor (opcional — ativa roteamento por intenção)
# Se configurado, mensagens com palavras-chave de vendas são roteadas para este flow
LANGFLOW_FLOW_VENDEDOR=
LANGFLOW_ROUTE_VENDEDOR=comprar,cotação,preço,proposta,seguro,plano,contratar,valor,orçamento

# Agente Secretária (opcional — ativa roteamento por intenção)
# Se configurado, mensagens com palavras-chave de agenda são roteadas para este flow
LANGFLOW_FLOW_SECRETARIA=
LANGFLOW_ROUTE_SECRETARIA=agendar,horário,reunião,agenda,marcar,visita,data,disponível

# Make (fallback — só necessário se não usar Langflow)
MAKE_WEBHOOK_URL=

# Rate limiting — máximo de mensagens por usuário por janela de tempo
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

PORT=3000
