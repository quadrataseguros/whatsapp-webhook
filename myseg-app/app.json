{
  "expo": {
    "name": "MYSeg",
    "slug": "myseg-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "myseg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1B4332"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quadrataseguros.myseg"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B4332"
      },
      "package": "com.quadrataseguros.myseg"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
